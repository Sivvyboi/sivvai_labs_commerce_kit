{
  "compilerOptions": {
    // Compile target: ES2020 gives us native async/await, optional chaining,
    // nullish coalescing, and BigInt — all supported by Next.js 16 runtime.
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    // Strict mode is non-negotiable. Never disable.
    "strict": true,
    // noEmit: Next.js handles compilation; tsc is for type-checking only.
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    // bundler: Aligns with Next.js Turbopack/Webpack module resolution.
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    // Next.js TypeScript plugin enables in-editor diagnostics for
    // Server/Client Component misuse, missing metadata exports, etc.
    "plugins": [
      {
        "name": "next"
      }
    ],
    // Single @/* alias mapping to the project root.
    // Usage: import { cn } from '@/lib/utils/cn'
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules", ".next", "out"]
}
