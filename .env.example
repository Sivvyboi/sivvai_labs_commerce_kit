# ============================================================================
# .env.example
#
# Template for ALL environment variables used by sivvai_labs_commerce_kit.
# This file is COMMITTED to version control — it contains no real secrets.
#
# Setup:
#   cp .env.example .env.local
#   # Then fill in real values in .env.local
#
# Rules:
# - NEXT_PUBLIC_* vars are bundled into the browser JavaScript.
#   Only put values here that are safe to expose to end users.
# - All other vars are server-only. Next.js strips them from the client bundle.
# - Never commit .env.local, .env, .env.development, or .env.production.
#   Only .env.example is safe to commit.
#
# Keep this file in sync with types/environment.d.ts.
# ============================================================================


# ----------------------------------------------------------------------------
# SITE IDENTITY (Public — safe for browser)
# ----------------------------------------------------------------------------

# Canonical origin URL for the storefront. No trailing slash.
# Used by next/image, sitemap, OG tags, and canonical links.
# Example: https://mystore.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Merchant contact details — displayed in footers, order emails, support pages.
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_CONTACT_PHONE=

# WhatsApp number in international format (used by whatsappCheckout feature).
# Example: +2348012345678
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Instagram handle WITHOUT the @ symbol.
# Example: mystore
NEXT_PUBLIC_INSTAGRAM_HANDLE=


# ----------------------------------------------------------------------------
# SUPABASE (Server-only — NEVER expose to client)
# ----------------------------------------------------------------------------

# Your Supabase project URL.
# Found in: Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL=

# Supabase anonymous (public) key.
# Found in: Supabase Dashboard → Project Settings → API → Project API Keys → anon / public
# Safe to expose to users, but kept server-side here for consistency.
SUPABASE_ANON_KEY=

# Supabase service role key.
# ⚠ DANGER: This key bypasses Row Level Security.
# Use ONLY in server-side admin operations. NEVER expose to the browser.
# Found in: Supabase Dashboard → Project Settings → API → Project API Keys → service_role
SUPABASE_SERVICE_ROLE_KEY=


# ----------------------------------------------------------------------------
# FEATURE FLAGS (Public — read by both server and client)
# All flags default to false (safe off) when the variable is unset.
# Set to "true" to enable.
# ----------------------------------------------------------------------------

# Enables user authentication (sign up, sign in, sign out).
# Requires Supabase Auth to be configured.
NEXT_PUBLIC_FEATURE_AUTH=false

# Enables the shopping cart and checkout flow.
NEXT_PUBLIC_FEATURE_CART=false

# Enables the search bar and product filtering.
NEXT_PUBLIC_FEATURE_SEARCH=false

# Enables product reviews and ratings.
NEXT_PUBLIC_FEATURE_REVIEWS=false

# Enables wishlist / saved items.
NEXT_PUBLIC_FEATURE_WISHLIST=false

# Enables the WhatsApp order flow (Buy Now → pre-filled WhatsApp message).
NEXT_PUBLIC_FEATURE_WHATSAPP_CHECKOUT=false
